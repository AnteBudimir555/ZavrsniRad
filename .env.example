# WHY THIS FILE EXISTS
# --------------------
# Docker Compose reads variables from a file called ".env" in the same folder.
# We commit ".env.example" as a *template* so anyone cloning the repo knows which
# variables to set, but we do NOT commit the real ".env" (put it in .gitignore).
#
# First-run:  copy this file to ".env"  ->  edit the values  ->  `docker compose up`.
#     Windows PowerShell:  Copy-Item .env.example .env
#     Git Bash / macOS:    cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=incidents
POSTGRES_USER=incident_user
POSTGRES_PASSWORD=change_me_strong_password

# --- JWT signing key (HS256) ---
# Generate with: openssl rand -base64 64
# Must be 64 random bytes, Base64-encoded (512-bit). Never reuse across environments.
JWT_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_64
# Token lifetime in milliseconds. 86400000 = 24 hours.
JWT_EXPIRATION_MS=86400000

# --- Seeded admin account (created on first backend startup) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
